<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="auth-page">
    <%- include('../partials/navbar') %>
    <main class="auth-shell">
        <section class="auth-card">
            <div class="auth-card__header">
                <div class="auth-badge">Q</div>
                <div>
                    <h1 class="auth-card__title">Welcome back</h1>
                    <p class="auth-card__subtitle">Sign in to manage your appointments with ease.</p>
                </div>
            </div>

            <div class="auth-card__body">
                <% if (error) { %>
                    <div class="alert alert-danger auth-alert" role="alert"><%= error %></div>
                <% } %>

                <% if (success) { %>
                    <div class="alert alert-success auth-alert" role="alert"><%= success %></div>
                <% } %>

                <form class="auth-form" method="POST" action="/login">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email address</label>
                        <input type="email" class="form-control auth-input" id="email" name="email" autocomplete="email" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control auth-input" id="password" name="password" autocomplete="current-password" required>
                    </div>
                    <button type="submit" class="btn auth-btn w-100">Login</button>
                </form>

                <div class="auth-footer">
                    <p class="mb-0"><a href="/">Back to public booking</a></p>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
