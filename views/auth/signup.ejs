<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="auth-page">
    <%- include('../partials/navbar') %>
    <main class="auth-shell">
        <section class="auth-card">
            <div class="auth-card__header">
                <div class="auth-badge">+</div>
                <div>
                    <h1 class="auth-card__title">Create your account</h1>
                    <p class="auth-card__subtitle">Join QueueEase and start managing your queue experience.</p>
                </div>
            </div>

            <div class="auth-card__body">
                <% if (error) { %>
                    <div class="alert alert-danger auth-alert" role="alert"><%= error %></div>
                <% } %>

                <form class="auth-form" method="POST" action="/signup">
                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" class="form-control auth-input" id="username" name="username" value="<%= formData.username || '' %>" required>
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email address</label>
                        <input type="email" class="form-control auth-input" id="email" name="email" value="<%= formData.email || '' %>" required>
                    </div>
                    <div class="mb-3">
                        <label for="contact" class="form-label">Contact number</label>
                        <input type="tel" class="form-control auth-input" id="contact" name="contact" value="<%= formData.contact || '' %>" required>
                    </div>
                    <div class="mb-3">
                        <label for="address" class="form-label">Address</label>
                        <input type="text" class="form-control auth-input" id="address" name="address" value="<%= formData.address || '' %>" required>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control auth-input" id="password" name="password" required>
                    </div>
                    <button type="submit" class="btn auth-btn w-100">Sign Up</button>
                </form>

                <div class="auth-footer">
                    <p class="mb-0">Already have an account? <a href="/login">Login here</a>.</p>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
