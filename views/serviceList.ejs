<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Service Management | QueueEase</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link rel="stylesheet" href="/css/service.css">
</head>

<body class="service-page">

<%- include('partials/navbar') %>

<div class="container py-5">

    <div class="service-hero mb-4">

        <div>

            <p class="service-label mb-1">
                QueueEase Administration
            </p>

            <h1>Service Management</h1>

            <p class="text-muted mb-0">
                Manage all available services within QueueEase.
            </p>

        </div>

        <a
            href="/service-management/add"
            class="btn btn-primary"
        >
            + Add Service
        </a>

    </div>

    <% if (successMessage) { %>

        <div class="alert alert-success">
            <%= successMessage %>
        </div>

    <% } %>

    <!-- Summary Cards -->

    <div class="row g-3 mb-4">

        <div class="col-md-4">

            <div class="service-summary-card">

                <p class="summary-title">
                    Total Services
                </p>

                <h2>
                    <%= services.length %>
                </h2>

            </div>

        </div>

        <div class="col-md-4">

            <div class="service-summary-card">

                <p class="summary-title">
                    Available
                </p>

                <h2>

                    <%= services.filter(service =>
                        service.status === 'Available'
                    ).length %>

                </h2>

            </div>

        </div>

        <div class="col-md-4">

            <div class="service-summary-card">

                <p class="summary-title">
                    Unavailable
                </p>

                <h2>

                    <%= services.filter(service =>
                        service.status === 'Unavailable'
                    ).length %>

                </h2>

            </div>

        </div>

    </div>

    <!-- Table -->

    <div class="service-table-card">

        <div class="table-responsive">

            <table class="table align-middle mb-0">

                <thead>

                    <tr>

                        <th>Service</th>

                        <th>Description</th>

                        <th>Duration</th>

                        <th>Price</th>

                        <th>Status</th>

                        <th>Actions</th>

                    </tr>

                </thead>

                <tbody>

                <% if (services.length === 0) { %>

                    <tr>

                        <td colspan="6" class="text-center py-5">

                            <h5>No services found</h5>

                            <p class="text-muted">

                                Start by adding your first service.

                            </p>

                            <a
                                href="/service-management/add"
                                class="btn btn-primary"
                            >

                                Add Service

                            </a>

                        </td>

                    </tr>

                <% } else { %>

                    <% services.forEach(service => { %>

                        <tr>

                            <td>

                                <strong>

                                    <%= service.serviceName %>

                                </strong>

                            </td>

                            <td>

                                <%= service.description ||
                                    'No description provided.' %>

                            </td>

                            <td>

                                <%= service.duration %> mins

                            </td>

                            <td>

                                $<%= Number(service.price).toFixed(2) %>

                            </td>

                            <td>

                                <span
                                    class="service-status
                                    <%= service.status === 'Available'
                                        ? 'status-available'
                                        : 'status-unavailable' %>"
                                >

                                    <%= service.status %>

                                </span>

                            </td>

                            <td>

                                <div class="d-flex gap-2">

                                    <a
                                        href="/service-management/<%= service.serviceID %>"
                                        class="btn btn-sm btn-outline-primary"
                                    >

                                        View

                                    </a>

                                    <a
                                        href="/service-management/<%= service.serviceID %>/edit"
                                        class="btn btn-sm btn-outline-secondary"
                                    >

                                        Edit

                                    </a>

                                </div>

                            </td>

                        </tr>

                    <% }) %>

                <% } %>

                </tbody>

            </table>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>