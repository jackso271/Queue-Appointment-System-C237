<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="auth-page">
    <%- include('../partials/navbar') %>
    <main class="auth-shell">
        <section class="auth-card">
            <div class="auth-card__header">
                <div class="auth-badge">✎</div>
                <div>
                    <h1 class="auth-card__title">Edit your profile</h1>
                    <p class="auth-card__subtitle">Keep your details current so your visits stay smooth.</p>
                </div>
            </div>

            <div class="auth-card__body">
                <% if (error) { %>
                    <div class="alert alert-danger auth-alert" role="alert"><%= error %></div>
                <% } %>

                <form class="auth-form" method="POST" action="/user/edit">
                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" class="form-control auth-input" id="username" name="username"
                               value="<%= user.username %>" autocomplete="name" required>
                    </div>
                    <div class="mb-3">
                        <label for="contact" class="form-label">Contact number</label>
                        <input type="tel" class="form-control auth-input" id="contact" name="contact"
                               value="<%= user.contact || '' %>" autocomplete="tel">
                    </div>
                    <div class="mb-3">
                        <label for="address" class="form-label">Address</label>
                        <input type="text" class="form-control auth-input" id="address" name="address"
                               value="<%= user.address || '' %>" autocomplete="street-address">
                    </div>
                    <button type="submit" class="btn auth-btn w-100">Save changes</button>
                </form>

                <div class="auth-footer">
                    <a href="/user/profile">Back to profile</a>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
