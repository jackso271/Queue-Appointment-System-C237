<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="auth-page">
    <%- include('../partials/navbar') %>
    <main class="auth-shell">
        <section class="auth-card">
            <div class="auth-card__header">
                <div class="auth-badge">🔒</div>
                <div>
                    <h1 class="auth-card__title">Change your password</h1>
                    <p class="auth-card__subtitle">Choose a strong password to protect your account.</p>
                </div>
            </div>

            <div class="auth-card__body">
                <% if (error) { %>
                    <div class="alert alert-danger auth-alert" role="alert"><%= error %></div>
                <% } %>

                <form class="auth-form" method="POST" action="/user/change-password">
                    <div class="mb-3">
                        <label for="currentPassword" class="form-label">Current password</label>
                        <input type="password" class="form-control auth-input" id="currentPassword" name="currentPassword" autocomplete="current-password" required>
                    </div>
                    <div class="mb-3">
                        <label for="newPassword" class="form-label">New password</label>
                        <input type="password" class="form-control auth-input" id="newPassword" name="newPassword" minlength="8" autocomplete="new-password" required>
                    </div>
                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">Confirm new password</label>
                        <input type="password" class="form-control auth-input" id="confirmPassword" name="confirmPassword" minlength="8" autocomplete="new-password" required>
                    </div>
                    <button type="submit" class="btn auth-btn w-100">Update password</button>
                </form>

                <div class="auth-footer">
                    <a href="/user/profile">Back to profile</a>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
