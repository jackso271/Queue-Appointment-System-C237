<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
    <main class="container py-5">
        <section class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h1 class="h4 mb-1">My Profile</h1>
                                <p class="text-muted mb-0">View and update your account information.</p>
                            </div>
                            <form method="POST" action="/auth/logout">
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Logout</button>
                            </form>
                        </div>

                        <% if (success) { %>
                            <div class="alert alert-success" role="alert"><%= success %></div>
                        <% } %>

                        <% if (error) { %>
                            <div class="alert alert-danger" role="alert"><%= error %></div>
                        <% } %>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 bg-white">
                                    <h2 class="h6 mb-2">Name</h2>
                                    <p class="mb-0"><%= user ? user.fullName : 'N/A' %></p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 bg-white">
                                    <h2 class="h6 mb-2">Email</h2>
                                    <p class="mb-0"><%= user ? user.email : 'N/A' %></p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 bg-white">
                                    <h2 class="h6 mb-2">Phone</h2>
                                    <p class="mb-0"><%= user ? user.phone : 'N/A' %></p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border rounded-3 p-3 bg-white">
                                    <h2 class="h6 mb-2">Role</h2>
                                    <p class="mb-0"><%= user ? user.role : 'N/A' %></p>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <a href="/user/edit" class="btn btn-outline-primary">Edit Profile</a>
                            <a href="/user/change-password" class="btn btn-outline-secondary ms-2">Change Password</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
