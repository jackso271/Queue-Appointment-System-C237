<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="auth-page">
    <main class="auth-shell">
        <section class="auth-card profile-card">
            <div class="auth-card__header profile-card__header">
                <div class="auth-badge">👤</div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <h1 class="auth-card__title">My Profile</h1>
                            <p class="auth-card__subtitle">View and update your account information.</p>
                        </div>
                        <form method="POST" action="/logout">
                            <button type="submit" class="btn btn-outline-secondary btn-sm profile-logout-btn">Logout</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="auth-card__body">
                <% if (success) { %>
                    <div class="alert alert-success auth-alert" role="alert"><%= success %></div>
                <% } %>

                <% if (error) { %>
                    <div class="alert alert-danger auth-alert" role="alert"><%= error %></div>
                <% } %>

                <div class="row g-3 profile-grid">
                    <div class="col-md-6">
                        <div class="profile-info-card">
                            <h2 class="profile-info-card__title">Username</h2>
                            <p class="profile-info-card__value"><%= user ? user.username : 'N/A' %></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="profile-info-card">
                            <h2 class="profile-info-card__title">Email</h2>
                            <p class="profile-info-card__value"><%= user ? user.email : 'N/A' %></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="profile-info-card">
                            <h2 class="profile-info-card__title">Contact</h2>
                            <p class="profile-info-card__value"><%= user ? user.contact : 'N/A' %></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="profile-info-card">
                            <h2 class="profile-info-card__title">Address</h2>
                            <p class="profile-info-card__value"><%= user ? user.address : 'N/A' %></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="profile-info-card">
                            <h2 class="profile-info-card__title">Role</h2>
                            <p class="profile-info-card__value"><%= user ? user.role : 'N/A' %></p>
                        </div>
                    </div>
                </div>

                <div class="profile-actions">
                    <a href="/user/edit" class="btn auth-btn profile-action-btn">Edit Profile</a>
                    <a href="/user/change-password" class="btn auth-btn profile-action-btn">Change Password</a>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
