<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Edit Service | QueueEase</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link rel="stylesheet" href="/css/service.css">
</head>

<body class="service-page">

<%- include('partials/navbar') %>

<div class="container py-5">

    <div class="service-form-card">

        <div class="mb-4">

            <p class="service-label mb-1">
                QueueEase Administration
            </p>

            <h1>Edit Service</h1>

            <p class="text-muted">
                Update the service information below.
            </p>

        </div>

        <% if (errorMessage) { %>

            <div class="alert alert-danger">
                <%= errorMessage %>
            </div>

        <% } %>

        <form
            action="/service-management/<%= service.serviceID %>/edit"
            method="POST"
        >

            <div class="mb-3">

                <label class="form-label">
                    Service Name
                </label>

                <input
                    type="text"
                    name="serviceName"
                    class="form-control"
                    maxlength="100"
                    required
                    value="<%= service.serviceName %>"
                >

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Description
                </label>

                <textarea
                    name="description"
                    rows="4"
                    class="form-control"
                    maxlength="500"
                ><%= service.description || '' %></textarea>

            </div>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Duration (minutes)
                    </label>

                    <input
                        type="number"
                        name="duration"
                        class="form-control"
                        min="1"
                        step="1"
                        required
                        value="<%= service.duration %>"
                    >

                </div>

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Price ($)
                    </label>

                    <input
                        type="number"
                        name="price"
                        class="form-control"
                        min="0"
                        step="0.01"
                        required
                        value="<%= service.price %>"
                    >

                </div>

            </div>

            <div class="mb-4">

                <label class="form-label">
                    Status
                </label>

                <select
                    name="status"
                    class="form-select"
                    required
                >

                    <option
                        value="Available"
                        <%= service.status === 'Available'
                            ? 'selected'
                            : '' %>
                    >
                        Available
                    </option>

                    <option
                        value="Unavailable"
                        <%= service.status === 'Unavailable'
                            ? 'selected'
                            : '' %>
                    >
                        Unavailable
                    </option>

                </select>

            </div>

            <div class="d-flex gap-2">

                <button
                    type="submit"
                    class="btn btn-primary"
                >
                    Save Changes
                </button>

                <a
                    href="/service-management/<%= service.serviceID %>"
                    class="btn btn-outline-secondary"
                >
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>