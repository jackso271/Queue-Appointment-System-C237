<%
    const navUser = typeof currentUser !== 'undefined' && currentUser ? currentUser : (typeof user !== 'undefined' ? user : null);
    const navRole = navUser && navUser.role ? String(navUser.role).toLowerCase() : '';
%>

<% if (navRole === 'staff') { %>
    <%- include('navbar-staff', { user: navUser, currentPath }) %>
<% } else if (navRole === 'admin') { %>
    <%- include('navbar-admin', { user: navUser, currentPath }) %>
<% } else { %>
    <%- include('navbar-public', { user: navUser, currentPath }) %>
<% } %>
