<%
    const isActive = (path) => currentPath === path;
    const isUsersActive = currentPath === '/admin/users' || currentPath === '/admin/users/create';
%>
<nav class="navbar navbar-expand-lg navbar-dark qe-navbar qe-navbar--admin">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/admin/dashboard">QueueEase Admin</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link <%= isActive('/admin/dashboard') ? 'active' : '' %>" href="/admin/dashboard">Admin</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= isActive('/feedback') ? 'active' : '' %>" href="/feedback">Feedback</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= isUsersActive ? 'active' : '' %>" href="/admin/users">Users</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= isActive('/reports/operational') ? 'active' : '' %>" href="/reports/operational">Report</a>
                </li>
                <li class="nav-item">
                    <form method="POST" action="/logout" class="d-inline">
                        <button class="btn btn-sm btn-outline-light qe-navbar__logout" type="submit">Logout</button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
</nav>
