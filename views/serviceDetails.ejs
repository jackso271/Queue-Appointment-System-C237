<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Service Details | QueueEase</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link rel="stylesheet" href="/css/service.css">
</head>

<body class="service-page">

<%- include('partials/navbar') %>

<div class="container py-5">

    <div class="service-details-card">

        <div
            class="d-flex justify-content-between
                   align-items-start flex-wrap gap-3 mb-4"
        >

            <div>

                <p class="service-label mb-1">
                    QueueEase Administration
                </p>

                <h1 class="mb-3">
                    <%= service.serviceName %>
                </h1>

                <span
                    class="service-status
                    <%= service.status === 'Available'
                        ? 'status-available'
                        : 'status-unavailable' %>"
                >
                    <%= service.status %>
                </span>

            </div>

            <div class="d-flex gap-2">

                <a
                    href="/service-management/<%= service.serviceID %>/edit"
                    class="btn btn-primary"
                >
                    Edit Service
                </a>

                <a
                    href="/service-management"
                    class="btn btn-outline-secondary"
                >
                    Back
                </a>

            </div>

        </div>

        <div class="service-detail-grid">

            <div class="service-detail-item">

                <span class="detail-label">
                    Description
                </span>

                <p class="mb-0">
                    <%= service.description ||
                        'No description provided.' %>
                </p>

            </div>

            <div class="service-detail-item">

                <span class="detail-label">
                    Duration
                </span>

                <p class="mb-0">
                    <%= service.duration %> minutes
                </p>

            </div>

            <div class="service-detail-item">

                <span class="detail-label">
                    Price
                </span>

                <p class="mb-0">
                    $<%= Number(service.price).toFixed(2) %>
                </p>

            </div>

            <div class="service-detail-item">

                <span class="detail-label">
                    Service ID
                </span>

                <p class="mb-0">
                    <%= service.serviceID %>
                </p>

            </div>

        </div>

        <hr class="my-4">

        <form
            action="/service-management/<%= service.serviceID %>/delete"
            method="POST"
            onsubmit="return confirm('Are you sure you want to delete this service?');"
        >

            <button
                type="submit"
                class="btn btn-outline-danger"
            >
                Delete Service
            </button>

        </form>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>