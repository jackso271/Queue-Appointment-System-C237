<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">

<%- include('../partials/navbar') %>

    <%
        const getStatusClass = (status) => {
            if (status === 'Waiting') return 'warning';
            if (status === 'Serving') return 'primary';
            if (status === 'Completed') return 'success';
            if (status === 'Cancelled') return 'secondary';
            return 'dark';
        };

        const formatQueueNumber = (value) => `Q${String(value || 0).padStart(3, '0')}`;
        const formatDate = (value) => {
            if (!value) return 'Not set';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return value;
            return date.toLocaleDateString('en-SG', { year: 'numeric', month: 'short', day: 'numeric' });
        };
        const formatTime = (value) => {
            if (!value) return 'Not set';
            if (typeof value === 'string') return value.slice(0, 5);
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return String(value);
            return date.toLocaleTimeString('en-SG', { hour: '2-digit', minute: '2-digit' });
        };
        const formatDateTime = (value) => {
            if (!value) return 'Not set';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return value;
            return `${formatDate(value)} ${formatTime(value)}`;
        };
    %>

    <main class="container py-4 py-lg-5">
        <!-- Queue page heading -->
        <section class="queue-hero bg-white border rounded-3 shadow-sm p-4 mb-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                <div>
                    <p class="text-uppercase text-primary fw-semibold small mb-2">Admin Queue Dashboard</p>
                    <h1 class="h2 mb-2">Queue Management</h1>
                    <p class="text-muted mb-0">Monitor active customers, call the next queue number, complete service, or cancel invalid queue entries.</p>
                </div>
                <div class="align-self-lg-center">
                    <a href="/" class="btn btn-outline-secondary">Back to Home</a>
                </div>
            </div>
        </section>

        <!-- Page messages -->
        <% if (authWarning) { %>
            <div class="alert alert-warning" role="alert"><%= authWarning %></div>
        <% } %>

        <% if (success) { %>
            <div class="alert alert-success" role="alert"><%= success %></div>
        <% } %>

        <% if (error) { %>
            <div class="alert alert-danger" role="alert"><%= error %></div>
        <% } %>

        <!-- Queue summary cards -->
        <section class="row g-3 mb-4" aria-label="Queue summary">
            <div class="col-md-4">
                <article class="queue-summary-card bg-white border rounded-3 p-4 h-100">
                    <p class="text-muted mb-1">Total Active Queue</p>
                    <div class="display-6 fw-bold"><%= totalActive || 0 %></div>
                </article>
            </div>
            <div class="col-md-4">
                <article class="queue-summary-card bg-white border rounded-3 p-4 h-100">
                    <p class="text-muted mb-1">Waiting</p>
                    <div class="display-6 fw-bold text-warning"><%= waitingCount || 0 %></div>
                </article>
            </div>
            <div class="col-md-4">
                <article class="queue-summary-card bg-white border rounded-3 p-4 h-100">
                    <p class="text-muted mb-1">Serving</p>
                    <div class="display-6 fw-bold text-primary"><%= servingCount || 0 %></div>
                </article>
            </div>
        </section>

        <!-- Active queue table -->
        <section class="bg-white border rounded-3 shadow-sm overflow-hidden">
            <div class="d-flex justify-content-between align-items-center px-4 py-3 border-bottom">
                <div>
                    <h2 class="h5 mb-1">Active Queue</h2>
                    <p class="text-muted small mb-0">Showing customers currently waiting or being served.</p>
                </div>
            </div>

            <% if (!queueEntries || queueEntries.length === 0) { %>
                <div class="queue-empty-state text-center p-5">
                    <h3 class="h5">No active queue records</h3>
                    <p class="text-muted mb-0">Waiting and serving customers will appear here after check-in.</p>
                </div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <caption class="visually-hidden">Active queue records</caption>
                        <thead class="table-dark">
                            <tr>
                                <th scope="col">Queue Number</th>
                                <th scope="col">Appointment ID</th>
                                <th scope="col">Customer Name</th>
                                <th scope="col">Service</th>
                                <th scope="col">Staff</th>
                                <th scope="col">Appointment Time</th>
                                <th scope="col">Appointment Status</th>
                                <th scope="col">Check-in Time</th>
                                <th scope="col">Status</th>
                                <th scope="col" class="text-lg-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% queueEntries.forEach((entry) => { %>
                                <tr>
                                    <td><span class="queue-number-badge"><%= formatQueueNumber(entry.queueNumber) %></span></td>
                                    <td><%= entry.appointmentID %></td>
                                    <td><%= entry.customerName || (entry.userID ? `Customer #${entry.userID}` : 'Customer unavailable') %></td>
                                    <td><%= entry.serviceName || 'Service unavailable' %></td>
                                    <td><%= entry.staffName || 'Not assigned' %></td>
                                    <td>
                                        <div><%= formatDate(entry.appointmentDate) %></div>
                                        <small class="text-muted"><%= formatTime(entry.appointmentTime) %></small>
                                    </td>
                                    <td><%= entry.appointmentStatus || 'Unknown' %></td>
                                    <td><%= formatDateTime(entry.checkInTime) %></td>
                                    <td>
                                        <span class="badge text-bg-<%= getStatusClass(entry.queueStatus) %>">
                                            <%= entry.queueStatus || 'Unknown' %>
                                        </span>
                                    </td>
                                    <td class="text-lg-end">
                                        <div class="d-flex flex-column flex-sm-row justify-content-lg-end gap-2">
                                            <% if (entry.queueStatus === 'Waiting') { %>
                                                <form action="/queue/admin/<%= entry.queueID %>/serving" method="POST">
                                                    <button type="submit" class="btn btn-sm btn-primary w-100" aria-label="Call customer <%= formatQueueNumber(entry.queueNumber) %>">Call Customer</button>
                                                </form>
                                                <form action="/queue/admin/<%= entry.queueID %>/cancel" method="POST" onsubmit="return confirm('Cancel this queue entry?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100" aria-label="Cancel queue <%= formatQueueNumber(entry.queueNumber) %>">Cancel</button>
                                                </form>
                                            <% } %>

                                            <% if (entry.queueStatus === 'Serving') { %>
                                                <form action="/queue/admin/<%= entry.queueID %>/completed" method="POST">
                                                    <button type="submit" class="btn btn-sm btn-success w-100" aria-label="Complete queue <%= formatQueueNumber(entry.queueNumber) %>">Complete</button>
                                                </form>
                                                <form action="/queue/admin/<%= entry.queueID %>/cancel" method="POST" onsubmit="return confirm('Cancel this queue entry?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100" aria-label="Cancel queue <%= formatQueueNumber(entry.queueNumber) %>">Cancel</button>
                                                </form>
                                            <% } %>

                                            <% if (entry.queueStatus !== 'Waiting' && entry.queueStatus !== 'Serving') { %>
                                                <span class="text-muted small">No actions available</span>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>
    </main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

