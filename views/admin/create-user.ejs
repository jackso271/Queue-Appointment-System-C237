<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create User Account | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
<%- include('../partials/navbar', { user }) %>

<main class="admin-page-shell">
    <div class="admin-page-header">
        <div>
            <p class="page-kicker">Admin</p>
            <h1 class="admin-page-title">Create User Account</h1>
            <p class="admin-page-subtitle">Add a secure QueueEase account with the required user profile fields.</p>
        </div>
        <a href="/admin/users" class="btn btn-outline-secondary admin-header-action">Back to Users</a>
    </div>

    <% if (error) { %>
        <div class="alert alert-danger admin-alert" role="alert"><%= error %></div>
    <% } %>
    <% if (success) { %>
        <div class="alert alert-success admin-alert" role="alert"><%= success %></div>
    <% } %>

    <section class="admin-card admin-form-card">
        <form action="/admin/users/create" method="POST" novalidate>
            <div class="form-grid">
                <div class="form-group">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="username" name="username" value="<%= formData.username || '' %>" maxlength="100" autocomplete="name" required>
                </div>

                <div class="form-group">
                    <label for="email" class="form-label">Email address</label>
                    <input type="email" class="form-control" id="email" name="email" value="<%= formData.email || '' %>" autocomplete="email" required>
                </div>

                <div class="form-group">
                    <label for="contact" class="form-label">Contact number</label>
                    <input type="tel" class="form-control" id="contact" name="contact" value="<%= formData.contact || '' %>" maxlength="20" autocomplete="tel" required>
                </div>

                <div class="form-group">
                    <label for="address" class="form-label">Address</label>
                    <input type="text" class="form-control" id="address" name="address" value="<%= formData.address || '' %>" maxlength="255" autocomplete="street-address" required>
                </div>

                <div class="form-group">
                    <label for="role" class="form-label">Role</label>
                    <select class="form-select" id="role" name="role" required>
                        <% roleOptions.forEach(role => { %>
                            <option value="<%= role %>" <%= (formData.role || 'Staff') === role ? 'selected' : '' %>><%= role %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="accountStatus" class="form-label">Account status</label>
                    <select class="form-select" id="accountStatus" name="accountStatus" required>
                        <% statusOptions.forEach(status => { %>
                            <option value="<%= status %>" <%= (formData.accountStatus || 'Active') === status ? 'selected' : '' %>><%= status %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password" name="password" minlength="8" autocomplete="new-password" required>
                </div>

                <div class="form-group">
                    <label for="confirmPassword" class="form-label">Confirm password</label>
                    <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" minlength="8" autocomplete="new-password" required>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Create User Account</button>
                <a href="/admin/users" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
