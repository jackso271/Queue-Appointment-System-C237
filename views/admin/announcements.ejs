<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Announcement Management | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
<%- include('../partials/navbar', { user }) %>

<%
    const rows = Array.isArray(announcements) ? announcements : [];
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const formatDate = (value) => {
        const date = value ? new Date(value) : null;
        return date && !Number.isNaN(date.getTime())
            ? date.toLocaleDateString('en-SG')
            : 'Not set';
    };
    const displayStatus = (item) => {
        const endDate = item.endDate ? new Date(item.endDate) : null;
        if (item.status === 'Active' && endDate && !Number.isNaN(endDate.getTime()) && endDate < today) {
            return 'Expired';
        }
        return item.status || 'Inactive';
    };
%>

<main class="admin-page-shell">
    <div class="admin-page-header">
        <div>
            <p class="page-kicker">Admin</p>
            <h1 class="admin-page-title">Announcement Management</h1>
            <p class="admin-page-subtitle">Create and manage clinic notices shown to public visitors before booking.</p>
        </div>
        <a href="/admin/announcements/create" class="btn btn-primary admin-header-action">Create Announcement</a>
    </div>

    <% if (error) { %>
        <div class="alert alert-danger admin-alert" role="alert"><%= error %></div>
    <% } %>
    <% if (success) { %>
        <div class="alert alert-success admin-alert" role="alert"><%= success %></div>
    <% } %>

    <section class="admin-card">
        <div class="table-card__header">
            <div>
                <h2 class="table-card__title">Announcements</h2>
                <p class="table-card__subtitle"><%= rows.length %> announcement<%= rows.length === 1 ? '' : 's' %> currently listed</p>
            </div>
        </div>

        <% if (rows.length === 0) { %>
            <div class="empty-state">
                <h3>No announcements found</h3>
                <p>Clinic announcements will appear here after they are created.</p>
                <a href="/admin/announcements/create" class="btn btn-primary">Create Announcement</a>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table announcement-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Announcement</th>
                            <th>Valid Dates</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% rows.forEach(item => {
                            const status = displayStatus(item);
                            const nextStatus = item.status === 'Active' ? 'Inactive' : 'Active';
                        %>
                            <tr>
                                <td class="text-muted fw-semibold">#<%= item.announcementID %></td>
                                <td>
                                    <div class="announcement-title"><%= item.title %></div>
                                    <div class="announcement-description">
                                        <%= item.description.length > 140 ? `${item.description.slice(0, 140)}...` : item.description %>
                                    </div>
                                </td>
                                <td>
                                    <div><%= formatDate(item.startDate) %></div>
                                    <div class="text-muted small">to <%= formatDate(item.endDate) %></div>
                                </td>
                                <td>
                                    <span class="status-badge status-badge--<%= String(status).toLowerCase() %>">
                                        <%= status %>
                                    </span>
                                </td>
                                <td><%= formatDate(item.createdAt) %></td>
                                <td>
                                    <div class="announcement-actions">
                                        <a href="/admin/announcements/<%= item.announcementID %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                                        <form action="/admin/announcements/<%= item.announcementID %>/status" method="POST">
                                            <input type="hidden" name="status" value="<%= nextStatus %>">
                                            <button type="submit" class="btn btn-sm btn-outline-secondary"><%= nextStatus %></button>
                                        </form>
                                        <form
                                            action="/admin/announcements/<%= item.announcementID %>/delete"
                                            method="POST"
                                            onsubmit="return confirm('Are you sure you want to delete this announcement?');"
                                        >
                                            <button type="submit" class="btn btn-sm btn-danger-outline">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
