<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
<%- include('../partials/navbar', { user }) %>

<main class="container py-4">
    <h1 class="h3 mb-3">Admin Dashboard</h1>
    <div class="row g-3">
        <div class="col-md-3">
            <div class="bg-white border rounded p-3">
                <p class="text-muted mb-1">Users</p>
                <div class="h2 mb-0"><%= statistics.totalUsers %></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white border rounded p-3">
                <p class="text-muted mb-1">Appointments</p>
                <div class="h2 mb-0"><%= statistics.totalAppointments %></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white border rounded p-3">
                <p class="text-muted mb-1">Waiting</p>
                <div class="h2 mb-0"><%= statistics.waitingCustomers %></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-white border rounded p-3">
                <p class="text-muted mb-1">Average Rating</p>
                <div class="h2 mb-0"><%= Number(statistics.averageRating || 0).toFixed(2) %></div>
            </div>
        </div>
    </div>

    <div class="bg-white border rounded p-3 mt-4">
        <h2 class="h5 mb-3">Admin Tools</h2>
        <div class="d-flex flex-wrap gap-2">
            <a href="/admin/staff" class="btn btn-primary">Staff Management</a>
            <a href="/admin/users" class="btn btn-outline-primary">User Management</a>
            <a href="/appointments" class="btn btn-outline-primary">Appointments</a>
            <a href="/queue/admin" class="btn btn-outline-primary">Queue Overview</a>
            <a href="/reports/operational" class="btn btn-outline-primary">Reports</a>
            <a href="/admin/announcements" class="btn btn-outline-primary">Announcements</a>
        </div>
    </div>

    <div class="row g-3 mt-2">
        <div class="col-lg-6">
            <div class="bg-white border rounded p-3">
                <h2 class="h5">Appointment Status</h2>
                <table class="table table-sm mb-0">
                    <tbody>
                        <% appointmentStatuses.forEach(item => { %>
                            <tr>
                                <td><%= item.status %></td>
                                <td class="text-end"><%= item.total %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="bg-white border rounded p-3">
                <h2 class="h5">Recent Feedback</h2>
                <% if (recentFeedback.length === 0) { %>
                    <p class="text-muted mb-0">No feedback submitted yet.</p>
                <% } else { %>
                    <table class="table table-sm mb-0">
                        <tbody>
                            <% recentFeedback.forEach(item => { %>
                                <tr>
                                    <td><%= item.customerName || 'Unknown customer' %></td>
                                    <td><%= item.serviceName || 'Unknown service' %></td>
                                    <td class="text-end"><%= item.rating %> / 5</td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>
    </div>
</main>
</body>
</html>
