<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
<%- include('../partials/navbar', { user }) %>

<main class="container py-4 py-lg-5">
    <section class="bg-white border rounded p-4">
        <p class="text-uppercase text-primary fw-semibold small mb-2">Booking successful</p>
        <h1 class="h3 mb-3">Your queue number is <span class="queue-number-badge"><%= queue.formattedQueueNumber %></span>.</h1>
        <p class="text-muted mb-4">Please keep this number and arrive before your selected appointment time.</p>

        <dl class="row mb-4">
            <dt class="col-sm-3">Booking ID</dt>
            <dd class="col-sm-9"><%= appointment.appointmentID %></dd>

            <dt class="col-sm-3">Queue Number</dt>
            <dd class="col-sm-9"><span class="queue-number-badge"><%= queue.formattedQueueNumber %></span></dd>

            <dt class="col-sm-3">Appointment Date</dt>
            <dd class="col-sm-9"><%= appointment.appointmentDate %></dd>

            <dt class="col-sm-3">Appointment Time</dt>
            <dd class="col-sm-9"><%= appointment.appointmentTime %></dd>

            <dt class="col-sm-3">Appointment Status</dt>
            <dd class="col-sm-9"><%= appointment.status %></dd>
        </dl>

        <div class="d-flex flex-wrap gap-2">
            <a href="/queue/status/<%= appointment.appointmentID %>" class="btn btn-primary">View Queue Status</a>
            <a href="/appointments/<%= appointment.appointmentID %>" class="btn btn-outline-primary">View Booking Details</a>
            <a href="/appointments/book" class="btn btn-outline-secondary">Book Another</a>
        </div>
    </section>
</main>
</body>
</html>
