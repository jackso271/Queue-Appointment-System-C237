<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Appointment</title>
</head>

<head>
    <meta charset="UTF-8">
    <title>Appointment Management System</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
<%- include('../partials/navbar') %>
    <h1>Edit Appointment</h1>
    <% if (error) { %>
        <p style="color:red;"><%= error %></p>
    <% } %>

    <form action="/appointments/edit/<%= appointment.appointmentID %>" method="POST">
        <label>Date:</label><br>
        <input type="date" name="appointmentDate" value="<%= appointment.appointmentDate %>" required><br><br>

        <label>Time:</label><br>
        <input type="time" name="appointmentTime" value="<%= appointment.appointmentTime %>" required><br><br>

        <label>Service:</label><br>
        <select name="serviceID" required>
            <option value="">Select a service</option>
            <% services.forEach(service => { %>
                <option value="<%= service.serviceID %>" <%= String(appointment.serviceID || '') === String(service.serviceID) ? 'selected' : '' %>>
                    <%= service.serviceName %>
                </option>
            <% }) %>
        </select><br><br>

        <label>Status:</label><br>
        <select name="status" required>
            <% ['Pending', 'Approved', 'Rejected', 'Completed', 'Cancelled'].forEach(status => { %>
                <option value="<%= status %>" <%= appointment.status === status ? 'selected' : '' %>>
                    <%= status %>
                </option>
            <% }) %>
        </select><br><br>

        <label>Notes:</label><br>
        <textarea name="remarks" rows="4" cols="30"><%= appointment.remarks || '' %></textarea><br><br>

        <button type="submit">Update Booking</button>
        <a href="/appointments">Cancel</a>
    </form>
</body>
</html>
