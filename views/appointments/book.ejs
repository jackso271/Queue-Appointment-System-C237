<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Appointment | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/appointment.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="main-container">
        <div class="card card-creative">
            <div class="card-gradient-bar"></div>
            <div class="card-body-content">
                <div class="card-subtitle"><i class="bi bi-sliders me-1"></i> QueueEase Administration</div>
                <h1 class="card-title">Let's Schedule an Appointment</h1>
                <p class="card-description">Fill out the quick form below to sync up with our advanced management queue ecosystem.</p>
                
                <% if (error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>

                <form action="/appointments/book" method="POST">
                    <div class="form-group">
                        <label class="form-label"><i class="bi bi-person-fill form-icon"></i>Customer Name</label>
                        <input type="text" name="customerName" class="form-control" value="<%= formData.customerName || '' %>" required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label class="form-label"><i class="bi bi-envelope-fill form-icon"></i>Email</label>
                            <input type="email" name="customerEmail" class="form-control" value="<%= formData.customerEmail || '' %>" required>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="form-label"><i class="bi bi-telephone-fill form-icon"></i>Phone</label>
                            <input type="tel" name="customerPhone" class="form-control" value="<%= formData.customerPhone || '' %>">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label class="form-label"><i class="bi bi-calendar-event-fill form-icon"></i>Preferred Date</label>
                            <input type="date" name="appointmentDate" class="form-control" value="<%= formData.appointmentDate || '' %>" required>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="form-label"><i class="bi bi-clock-fill form-icon"></i>Preferred Time</label>
                            <input type="time" name="appointmentTime" class="form-control" value="<%= formData.appointmentTime || '' %>" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label"><i class="bi bi-layers-fill form-icon"></i>Service</label>
                        <select name="serviceID" class="form-control" required>
                            <option value="">Select a service</option>
                            <% services.forEach(service => { %>
                                <option value="<%= service.serviceID %>" <%= String(formData.serviceID || '') === String(service.serviceID) ? 'selected' : '' %>>
                                    <%= service.serviceName %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label"><i class="bi bi-chat-left-text-fill form-icon"></i>Notes / Special Requirements</label>
                        <textarea name="remarks" class="form-control" placeholder="Provide details..."><%= formData.remarks || '' %></textarea>
                    </div>

                    <div class="btn-group-creative">
                        <button type="submit" class="btn-booking-vibrant">
                            <i class="bi bi-check-circle-fill me-2"></i>Confirm & Book Now
                        </button>
                        <a href="/" class="btn-cancel-outline">
                            <i class="bi bi-x-circle me-1"></i>Discard
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

</body>
</html>
