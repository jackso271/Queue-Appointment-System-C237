<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Appointment | QueueEase</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/service-management">
                QueueEase
            </a>

            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#mainNavbar"
                aria-controls="mainNavbar"
                aria-expanded="false"
                aria-label="Toggle navigation"
            >
                <span class="navbar-toggler-icon"></span>
            </button>

            <div
                class="collapse navbar-collapse"
                id="mainNavbar"
            >
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a
                            class="nav-link"
                            href="/queue-management"
                        >
                            Queue Management
                        </a>
                    </li>

                    <li class="nav-item">
                        <a
                            class="nav-link"
                            href="/service-management"
                        >
                            Service Management
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="main-container">
        <div class="card">
            <div class="card-subtitle">QueueEase Administration</div>
            <h1 class="card-title">Book an Appointment</h1>
            <p class="card-description">Schedule customer consulting and specialized management services.</p>
            
            <form action="/book" method="POST">
                <div class="form-group">
                    <label class="form-label">Customer Name</label>
                    <input type="text" name="customer_name" class="form-control" placeholder="John Doe" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Customer Email</label>
                    <input type="email" name="customer_email" class="form-control" placeholder="johndoe@example.com" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Preferred Date</label>
                    <input type="date" name="appointmentDate" class="form-control" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Preferred Time</label>
                    <input type="time" name="appointmentTime" class="form-control" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Notes / Requirements</label>
                    <textarea name="remarks" class="form-control" placeholder="Provide any specific documents or requests..."></textarea>
                </div>

                <div class="btn-group">
                    <button type="submit" class="btn-booking">Submit Booking</button>
                    <a href="/" class="btn-cancel">Cancel</a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>