<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booking Details | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
<%- include('../partials/navbar', { user }) %>

<main class="container py-4">
    <div class="bg-white border rounded p-4">
        <h1 class="h3">Booking Details</h1>
        <p class="text-muted">Booking ID: <strong><%= appointment.appointmentID %></strong></p>

        <dl class="row">
            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9"><%= appointment.customerName %></dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9"><%= appointment.customerEmail %></dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9"><%= appointment.customerPhone || 'Not provided' %></dd>

            <dt class="col-sm-3">Service</dt>
            <dd class="col-sm-9"><%= appointment.serviceName || 'Unknown service' %></dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9"><%= appointment.appointmentDate %></dd>

            <dt class="col-sm-3">Time</dt>
            <dd class="col-sm-9"><%= appointment.appointmentTime %></dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><%= appointment.status %></dd>

            <dt class="col-sm-3">Remarks</dt>
            <dd class="col-sm-9"><%= appointment.remarks || 'None' %></dd>
        </dl>

        <div class="d-flex flex-wrap gap-2">
            <a href="/queue/status/<%= appointment.appointmentID %>" class="btn btn-primary">Queue Status</a>
            <a href="/feedback/add/<%= appointment.appointmentID %>" class="btn btn-outline-primary">Submit Feedback</a>
            <a href="/appointments/book" class="btn btn-outline-secondary">Book Another</a>
        </div>
    </div>
</main>
</body>
</html>
