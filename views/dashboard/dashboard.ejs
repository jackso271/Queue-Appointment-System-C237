<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title><%= title || 'Operational Dashboard' %> | QueueEase</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

<%- include('../partials/navbar') %>

<main class="container py-4 py-lg-5">

    <section class="bg-white border rounded-3 shadow-sm p-4 mb-4">

        <p class="text-uppercase text-primary fw-semibold small mb-2">
            QueueEase Administration
        </p>

        <h1 class="h2 mb-2">
            Operational Dashboard
        </h1>

        <p class="text-muted mb-0">
            Monitor users, appointments, queue activity and customer ratings.
        </p>

    </section>

    <%
        const stats = statistics || {};
    %>

    <section class="row g-3 mb-4">

        <div class="col-sm-6 col-lg-3">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Total Users
                </p>

                <div class="display-6 fw-bold">
                    <%= stats.totalUsers || 0 %>
                </div>

            </article>

        </div>

        <div class="col-sm-6 col-lg-3">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Available Services
                </p>

                <div class="display-6 fw-bold text-success">
                    <%= stats.availableServices || 0 %>
                </div>

            </article>

        </div>

        <div class="col-sm-6 col-lg-3">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Waiting Customers
                </p>

                <div class="display-6 fw-bold text-warning">
                    <%= stats.waitingCustomers || 0 %>
                </div>

            </article>

        </div>

        <div class="col-sm-6 col-lg-3">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Average Rating
                </p>

                <div class="display-6 fw-bold">

                    <%= Number(
                        stats.averageRating || 0
                    ).toFixed(2) %>

                    <span class="fs-6 text-muted">
                        / 5
                    </span>

                </div>

            </article>

        </div>

        <div class="col-sm-6 col-lg-4">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Total Appointments
                </p>

                <div class="display-6 fw-bold">
                    <%= stats.totalAppointments || 0 %>
                </div>

            </article>

        </div>

        <div class="col-sm-6 col-lg-4">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Completed Appointments
                </p>

                <div class="display-6 fw-bold text-success">
                    <%= stats.completedAppointments || 0 %>
                </div>

            </article>

        </div>

        <div class="col-sm-6 col-lg-4">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Total Feedback
                </p>

                <div class="display-6 fw-bold">
                    <%= stats.totalFeedback || 0 %>
                </div>

            </article>

        </div>

    </section>

    <section class="row g-4">

        <div class="col-lg-6">

            <article
                class="bg-white border rounded-3 shadow-sm h-100
                       overflow-hidden"
            >

                <div class="px-4 py-3 border-bottom">

                    <h2 class="h5 mb-1">
                        Appointment Status
                    </h2>

                    <p class="text-muted small mb-0">
                        Number of appointments grouped by status.
                    </p>

                </div>

                <% if (
                    !Array.isArray(appointmentStatuses) ||
                    appointmentStatuses.length === 0
                ) { %>

                    <div class="p-4 text-muted">
                        No appointment data available.
                    </div>

                <% } else { %>

                    <div class="table-responsive">

                        <table class="table table-hover mb-0">

                            <thead class="table-light">

                                <tr>
                                    <th class="px-4">Status</th>
                                    <th>Total</th>
                                </tr>

                            </thead>

                            <tbody>

                                <% appointmentStatuses.forEach(item => { %>

                                    <tr>
                                        <td class="px-4">
                                            <%= item.status %>
                                        </td>

                                        <td class="fw-semibold">
                                            <%= item.total %>
                                        </td>
                                    </tr>

                                <% }) %>

                            </tbody>

                        </table>

                    </div>

                <% } %>

            </article>

        </div>

        <div class="col-lg-6">

            <article
                class="bg-white border rounded-3 shadow-sm h-100
                       overflow-hidden"
            >

                <div class="px-4 py-3 border-bottom">

                    <h2 class="h5 mb-1">
                        Rating Breakdown
                    </h2>

                    <p class="text-muted small mb-0">
                        Number of responses received for each rating.
                    </p>

                </div>

                <% if (
                    !Array.isArray(ratingBreakdown) ||
                    ratingBreakdown.length === 0
                ) { %>

                    <div class="p-4 text-muted">
                        No rating information available.
                    </div>

                <% } else { %>

                    <div class="table-responsive">

                        <table class="table table-hover mb-0">

                            <thead class="table-light">

                                <tr>
                                    <th class="px-4">Rating</th>
                                    <th>Total</th>
                                </tr>

                            </thead>

                            <tbody>

                                <% ratingBreakdown.forEach(item => { %>

                                    <tr>

                                        <td class="px-4">
                                            <span class="badge text-bg-warning">
                                                <%= item.rating %> / 5
                                            </span>
                                        </td>

                                        <td class="fw-semibold">
                                            <%= item.total %>
                                        </td>

                                    </tr>

                                <% }) %>

                            </tbody>

                        </table>

                    </div>

                <% } %>

            </article>

        </div>

        <div class="col-12">

            <article
                class="bg-white border rounded-3 shadow-sm overflow-hidden"
            >

                <div
                    class="d-flex justify-content-between
                           align-items-center px-4 py-3 border-bottom"
                >

                    <div>
                        <h2 class="h5 mb-1">
                            Recent Feedback
                        </h2>

                        <p class="text-muted small mb-0">
                            Latest customer feedback submissions.
                        </p>
                    </div>

                    <a
                        href="/feedback"
                        class="btn btn-sm btn-outline-primary"
                    >
                        View All Feedback
                    </a>

                </div>

                <% if (
                    !Array.isArray(recentFeedback) ||
                    recentFeedback.length === 0
                ) { %>

                    <div class="p-4 text-muted">
                        No recent feedback available.
                    </div>

                <% } else { %>

                    <div class="table-responsive">

                        <table class="table table-hover align-middle mb-0">

                            <thead class="table-light">

                                <tr>
                                    <th class="px-4">Customer</th>
                                    <th>Service</th>
                                    <th>Rating</th>
                                    <th>Comments</th>
                                </tr>

                            </thead>

                            <tbody>

                                <% recentFeedback.forEach(item => { %>

                                    <tr>

                                        <td class="px-4 fw-semibold">
                                            <%= item.customerName ||
                                                'Unknown customer' %>
                                        </td>

                                        <td>
                                            <%= item.serviceName ||
                                                'Unknown service' %>
                                        </td>

                                        <td>
                                            <span class="badge text-bg-warning">
                                                <%= item.rating %> / 5
                                            </span>
                                        </td>

                                        <td>
                                            <%= item.comments ||
                                                'No comments provided' %>
                                        </td>

                                    </tr>

                                <% }) %>

                            </tbody>

                        </table>

                    </div>

                <% } %>

            </article>

        </div>

    </section>

</main>

<script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
></script>

</body>
</html>