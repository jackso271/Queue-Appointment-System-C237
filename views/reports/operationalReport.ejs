<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title><%= title || 'Operational Report' %> | QueueEase</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

<%- include('../partials/navbar') %>

<main class="container py-4 py-lg-5">

    <section class="bg-white border rounded-3 shadow-sm p-4 mb-4">

        <div
            class="d-flex flex-column flex-md-row
                   justify-content-between align-items-md-center gap-3"
        >

            <div>

                <p class="text-uppercase text-primary fw-semibold small mb-2">
                    QueueEase Administration
                </p>

                <h1 class="h2 mb-2">
                    Operational Report
                </h1>

                <p class="text-muted mb-0">
                    Review appointment activity, service usage and feedback
                    performance.
                </p>

            </div>

            <button
                type="button"
                class="btn btn-outline-primary"
                onclick="window.print()"
            >
                Print Report
            </button>

        </div>

    </section>

    <%
        const summary = feedbackSummary || {};
    %>

    <section class="row g-3 mb-4">

        <div class="col-sm-6 col-lg-3">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Total Feedback
                </p>

                <div class="display-6 fw-bold">
                    <%= summary.totalFeedback || 0 %>
                </div>

            </article>

        </div>

        <div class="col-sm-6 col-lg-3">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Average Rating
                </p>

                <div class="display-6 fw-bold">

                    <%= Number(
                        summary.averageRating || 0
                    ).toFixed(2) %>

                </div>

            </article>

        </div>

        <div class="col-sm-6 col-lg-3">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Lowest Rating
                </p>

                <div class="display-6 fw-bold text-danger">
                    <%= summary.lowestRating || 0 %>
                </div>

            </article>

        </div>

        <div class="col-sm-6 col-lg-3">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Highest Rating
                </p>

                <div class="display-6 fw-bold text-success">
                    <%= summary.highestRating || 0 %>
                </div>

            </article>

        </div>

    </section>

    <section class="row g-4">

        <div class="col-lg-6">

            <article
                class="bg-white border rounded-3 shadow-sm
                       overflow-hidden h-100"
            >

                <div class="px-4 py-3 border-bottom">

                    <h2 class="h5 mb-1">
                        Appointments by Status
                    </h2>

                    <p class="text-muted small mb-0">
                        Appointment totals grouped by current status.
                    </p>

                </div>

                <% if (
                    !Array.isArray(appointmentsByStatus) ||
                    appointmentsByStatus.length === 0
                ) { %>

                    <div class="p-4 text-muted">
                        No appointment status information available.
                    </div>

                <% } else { %>

                    <div class="table-responsive">

                        <table class="table table-hover mb-0">

                            <thead class="table-light">

                                <tr>
                                    <th class="px-4">Status</th>
                                    <th>Total</th>
                                </tr>

                            </thead>

                            <tbody>

                                <% appointmentsByStatus.forEach(item => { %>

                                    <tr>
                                        <td class="px-4">
                                            <%= item.status %>
                                        </td>

                                        <td class="fw-semibold">
                                            <%= item.total %>
                                        </td>
                                    </tr>

                                <% }) %>

                            </tbody>

                        </table>

                    </div>

                <% } %>

            </article>

        </div>

        <div class="col-lg-6">

            <article
                class="bg-white border rounded-3 shadow-sm
                       overflow-hidden h-100"
            >

                <div class="px-4 py-3 border-bottom">

                    <h2 class="h5 mb-1">
                        Monthly Appointments
                    </h2>

                    <p class="text-muted small mb-0">
                        Total appointment activity for each month.
                    </p>

                </div>

                <% if (
                    !Array.isArray(monthlyAppointments) ||
                    monthlyAppointments.length === 0
                ) { %>

                    <div class="p-4 text-muted">
                        No monthly appointment information available.
                    </div>

                <% } else { %>

                    <div class="table-responsive">

                        <table class="table table-hover mb-0">

                            <thead class="table-light">

                                <tr>
                                    <th class="px-4">Month</th>
                                    <th>Total Appointments</th>
                                </tr>

                            </thead>

                            <tbody>

                                <% monthlyAppointments.forEach(item => { %>

                                    <tr>
                                        <td class="px-4">
                                            <%= item.reportMonth %>
                                        </td>

                                        <td class="fw-semibold">
                                            <%= item.totalAppointments %>
                                        </td>
                                    </tr>

                                <% }) %>

                            </tbody>

                        </table>

                    </div>

                <% } %>

            </article>

        </div>

        <div class="col-12">

            <article
                class="bg-white border rounded-3 shadow-sm overflow-hidden"
            >

                <div class="px-4 py-3 border-bottom">

                    <h2 class="h5 mb-1">
                        Appointments by Service
                    </h2>

                    <p class="text-muted small mb-0">
                        Compare demand across QueueEase services.
                    </p>

                </div>

                <% if (
                    !Array.isArray(appointmentsByService) ||
                    appointmentsByService.length === 0
                ) { %>

                    <div class="p-4 text-muted">
                        No service appointment information available.
                    </div>

                <% } else { %>

                    <div class="table-responsive">

                        <table class="table table-hover align-middle mb-0">

                            <thead class="table-light">

                                <tr>
                                    <th class="px-4">Service</th>
                                    <th>Total Appointments</th>
                                </tr>

                            </thead>

                            <tbody>

                                <% appointmentsByService.forEach(item => { %>

                                    <tr>

                                        <td class="px-4 fw-semibold">
                                            <%= item.serviceName %>
                                        </td>

                                        <td>
                                            <%= item.totalAppointments %>
                                        </td>

                                    </tr>

                                <% }) %>

                            </tbody>

                        </table>

                    </div>

                <% } %>

            </article>

        </div>

    </section>

</main>

<script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
></script>

</body>
</html>