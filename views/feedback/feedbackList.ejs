<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Feedback Management | QueueEase</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

<%- include('../partials/navbar') %>

<main class="container py-4 py-lg-5">
    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <section class="bg-white border rounded-3 shadow-sm p-4 mb-4">

        <div
            class="d-flex flex-column flex-md-row
                   justify-content-between align-items-md-center gap-3"
        >
            <div>
                <p class="text-uppercase text-primary fw-semibold small mb-2">
                    QueueEase Administration
                </p>

                <h1 class="h2 mb-2">
                    Feedback Management
                </h1>

                <p class="text-muted mb-0">
                    View and manage customer feedback submitted for completed
                    appointments.
                </p>
            </div>
        </div>

    </section>

    <section class="row g-3 mb-4">

        <div class="col-md-6">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Total Feedback
                </p>

                <div class="display-6 fw-bold">
                    <%= Array.isArray(feedback) ? feedback.length : 0 %>
                </div>

            </article>

        </div>

        <div class="col-md-6">

            <article class="bg-white border rounded-3 p-4 h-100">

                <p class="text-muted mb-1">
                    Average Rating
                </p>

                <div class="display-6 fw-bold">

                    <%
                        const feedbackRows =
                            Array.isArray(feedback) ? feedback : [];

                        const averageRating =
                            feedbackRows.length > 0
                                ? feedbackRows.reduce(
                                    (sum, item) =>
                                        sum + Number(item.rating || 0),
                                    0
                                ) / feedbackRows.length
                                : 0;
                    %>

                    <%= averageRating.toFixed(2) %> / 5

                </div>

            </article>

        </div>

    </section>

    <section
        class="bg-white border rounded-3 shadow-sm overflow-hidden"
    >

        <div class="px-4 py-3 border-bottom">

            <h2 class="h5 mb-1">
                Feedback Records
            </h2>

            <p class="text-muted small mb-0">
                Feedback is displayed from newest to oldest.
            </p>

        </div>

        <% if (!Array.isArray(feedback) || feedback.length === 0) { %>

            <div class="p-5 text-center">

                <h3 class="h5">
                    No feedback found
                </h3>

                <p class="text-muted mb-0">
                    Customer feedback will appear here after submission.
                </p>

            </div>

        <% } else { %>

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>
                            <th class="px-4 py-3">Customer</th>
                            <th class="py-3">Appointment</th>
                            <th class="py-3">Rating</th>
                            <th class="py-3">Comments</th>
                            <th class="py-3">Submitted</th>
                            <th class="py-3">Actions</th>
                        </tr>

                    </thead>

                    <tbody>

                        <% feedback.forEach(item => { %>

                            <tr>

                                <td class="px-4 py-3 fw-semibold">
                                    <%= item.customerName || 'Unknown customer' %>
                                    <div class="text-muted small fw-normal">
                                        <%= item.customerEmail || 'No email' %>
                                    </div>
                                </td>

                                <td>
                                    <div class="fw-semibold">
                                        #<%= item.appointmentID %>
                                        <% if (item.queueNumber) { %>
                                            <span class="text-muted">
                                                Q<%= String(item.queueNumber).padStart(3, '0') %>
                                            </span>
                                        <% } %>
                                    </div>
                                    <div class="text-muted small">
                                        <%= item.serviceName || 'Unknown service' %>
                                    </div>
                                    <div class="text-muted small">
                                        <%= item.appointmentDate %> <%= item.appointmentTime %>
                                    </div>
                                </td>

                                <td>

                                    <span class="badge text-bg-warning">
                                        <%- '&#9733;'.repeat(Number(item.rating || 0)) %>
                                        <span class="visually-hidden"><%= item.rating %> / 5</span>
                                    </span>

                                </td>

                                <td style="max-width: 320px;">

                                    <%= item.comments || 'No comments provided' %>

                                </td>

                                <td>

                                    <%
                                        const submittedDate =
                                            item.submittedDate
                                                ? new Date(item.submittedDate)
                                                : null;
                                    %>

                                    <%= submittedDate &&
                                        !Number.isNaN(submittedDate.getTime())
                                            ? submittedDate.toLocaleString(
                                                'en-SG'
                                            )
                                            : 'Not available'
                                    %>

                                </td>

                                <td>

                                    <div class="d-flex flex-wrap gap-2">

                                        <a
                                            href="/feedback/<%= item.feedbackID %>"
                                            class="btn btn-sm btn-outline-primary"
                                        >
                                            View
                                        </a>

                                        <a
                                            href="/feedback/edit/<%= item.feedbackID %>"
                                            class="btn btn-sm btn-outline-secondary"
                                        >
                                            Edit
                                        </a>

                                        <form
                                            action="/feedback/delete/<%= item.feedbackID %>"
                                            method="POST"
                                            onsubmit="return confirm(
                                                'Delete this feedback?'
                                            );"
                                        >
                                            <button
                                                type="submit"
                                                class="btn btn-sm btn-outline-danger"
                                            >
                                                Delete
                                            </button>
                                        </form>

                                    </div>

                                </td>

                            </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        <% } %>

    </section>

</main>

<script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
></script>

</body>
</html>
