<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Feedback | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
<%- include('../partials/navbar', { user }) %>

<main class="container py-4">
    <div class="bg-white border rounded p-4">
        <h1 class="h3">Edit Feedback</h1>
        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <form action="/feedback/edit/<%= feedback.feedbackID %>" method="POST">
            <div class="mb-3">
                <label class="form-label">Rating</label>
                <select name="rating" class="form-select" required>
                    <% [5, 4, 3, 2, 1].forEach(rating => { %>
                        <option value="<%= rating %>" <%= Number(feedback.rating) === rating ? 'selected' : '' %>><%= rating %></option>
                    <% }) %>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Comments</label>
                <textarea class="form-control" name="comments" rows="5"><%= feedback.comments || '' %></textarea>
            </div>
            <button class="btn btn-primary" type="submit">Save</button>
            <a href="/feedback" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</main>
</body>
</html>
