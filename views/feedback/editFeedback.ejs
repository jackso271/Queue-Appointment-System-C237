<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Feedback | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
<%- include('../partials/navbar', { user }) %>

<%
    const isAdmin = user && user.role === 'Admin';
    const queryEmail = customerEmail ? `?email=${encodeURIComponent(customerEmail)}` : '';
    const formAction = isAdmin
        ? `/feedback/edit/${feedback.feedbackID}`
        : `/feedback/${feedback.feedbackID}/edit${queryEmail}`;
    const selectedRating = formData && formData.rating ? Number(formData.rating) : Number(feedback.rating);
    const commentsValue = formData && typeof formData.comments !== 'undefined'
        ? formData.comments
        : (feedback.comments || '');
%>

<main class="container py-4 py-lg-5">
    <section class="bg-white border rounded-3 shadow-sm p-4 p-lg-5">
        <div class="mb-4">
            <p class="text-uppercase text-primary fw-semibold small mb-2">
                Feedback #<%= feedback.feedbackID %>
            </p>
            <h1 class="h3 mb-2">Edit Feedback</h1>
            <p class="text-muted mb-0">
                Booking #<%= feedback.appointmentID %> for
                <%= feedback.serviceName || 'Unknown service' %>.
            </p>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="<%= formAction %>" method="POST">
            <% if (customerEmail) { %>
                <input type="hidden" name="customerEmail" value="<%= customerEmail %>">
            <% } %>

            <div class="mb-3">
                <label class="form-label" for="rating">Rating</label>
                <select id="rating" name="rating" class="form-select" required>
                    <% [5, 4, 3, 2, 1].forEach(rating => { %>
                        <option value="<%= rating %>" <%= selectedRating === rating ? 'selected' : '' %>>
                            <%= rating %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label" for="comments">Comments</label>
                <textarea
                    id="comments"
                    class="form-control"
                    name="comments"
                    rows="6"
                    maxlength="500"
                    required
                ><%= commentsValue %></textarea>
                <div class="form-text">Maximum 500 characters.</div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-primary" type="submit">Save</button>
                <a href="<%= backUrl || '/feedback' %>" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </section>
</main>
</body>
</html>
