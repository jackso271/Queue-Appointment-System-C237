<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('../partials/navbar', { user }) %>

<main class="container py-5">
    <div class="bg-white border rounded p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1"><%= staff.fullName %></h1>
                <p class="text-muted mb-0">Staff details</p>
            </div>
            <a href="/admin/staff" class="btn btn-outline-secondary">Back</a>
        </div>

        <dl class="row">
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9"><%= staff.email %></dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9"><%= staff.phone || 'Not provided' %></dd>

            <dt class="col-sm-3">Position</dt>
            <dd class="col-sm-9"><%= staff.position %></dd>

            <dt class="col-sm-3">Availability</dt>
            <dd class="col-sm-9"><%= staff.availabilityStatus %></dd>
        </dl>

        <a href="/admin/staff/<%= staff.staffID %>/edit" class="btn btn-primary">Edit</a>
    </div>
</main>
</body>
</html>
