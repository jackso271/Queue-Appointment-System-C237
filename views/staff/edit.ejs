<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('../partials/navbar') %>
<div class="container py-5">
    <div class="bg-white shadow-sm rounded-3 p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1">Edit Staff</h1>
                <p class="text-muted mb-0">Update the selected staff member.</p>
            </div>
            <a href="/admin/staff" class="btn btn-outline-secondary">Back</a>
        </div>
        <% if (typeof error !== 'undefined') { %>
            <div class="alert alert-danger">
                <%= error %>
            </div>
        <% } %>
        <form action="/admin/staff/<%= staff.staffID %>/edit" method="POST">
            <div class="mb-3">
                <label for="fullName" class="form-label">Full Name</label>
                <input type="text" id="fullName" name="fullName" class="form-control" value="<%= staff.fullName %>" required>
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" name="email" class="form-control" value="<%= staff.email %>" required>
            </div>
            <div class="mb-3">
                <label for="phone" class="form-label">Phone</label>
                <input type="text" id="phone" name="phone" class="form-control" value="<%= staff.phone || '' %>">
            </div>
            <div class="mb-3">
                <label for="position" class="form-label">Position</label>
                <input type="text" id="position" name="position" class="form-control" value="<%= staff.position %>" required>
            </div>
            <div class="mb-4">
                <label for="availabilityStatus" class="form-label">Availability</label>
                <select id="availabilityStatus" name="availabilityStatus" class="form-select" required>
                    <option value="Available" <%= staff.availabilityStatus === 'Available' ? 'selected' : '' %>>
                        Available
                    </option>
                    <option value="Unavailable" <%= staff.availabilityStatus === 'Unavailable' ? 'selected' : '' %>>
                        Unavailable
                    </option>
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Update Staff</button>
                <a href="/admin/staff/<%= staff.staffID %>" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
