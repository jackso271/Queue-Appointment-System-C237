<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staff Dashboard | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
<%- include('../partials/navbar', { user }) %>

<main class="container py-4">
    <h1 class="h3 mb-3">Staff Dashboard</h1>
    <div class="row g-3">
        <div class="col-md-4">
            <div class="bg-white border rounded p-3">
                <p class="text-muted mb-1">Assigned Appointments</p>
                <div class="h2 mb-0"><%= assignedCount %></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="bg-white border rounded p-3">
                <p class="text-muted mb-1">Waiting Queue</p>
                <div class="h2 mb-0"><%= waitingCount %></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="bg-white border rounded p-3">
                <p class="text-muted mb-1">Completed Today</p>
                <div class="h2 mb-0"><%= completedToday %></div>
            </div>
        </div>
    </div>

    <div class="mt-4 bg-white border rounded p-3">
        <h2 class="h5">My Assigned Appointments</h2>
        <% if (appointments.length === 0) { %>
            <p class="text-muted mb-0">No appointments assigned.</p>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Service</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% appointments.forEach(item => { %>
                            <tr>
                                <td><%= item.appointmentDate %></td>
                                <td><%= item.appointmentTime %></td>
                                <td><%= item.serviceName || 'N/A' %></td>
                                <td><%= item.status %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</main>
</body>
</html>
