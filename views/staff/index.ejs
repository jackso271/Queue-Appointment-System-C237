<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | QueueEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('../partials/navbar') %>
<main class="container py-4 py-lg-5">
    <section class="bg-white border rounded-3 shadow-sm p-4 mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
            <div>
                <p class="text-uppercase text-primary fw-semibold small mb-2">QueueEase Administration</p>
                <h1 class="h2 mb-2">Staff Management</h1>
                <p class="text-muted mb-0">View, search and manage staff records.</p>
            </div>
            <div class="align-self-md-center">
                <a href="/staff/create" class="btn btn-primary">Add Staff</a>
            </div>
        </div>
    </section>
    <section class="bg-white border rounded-3 shadow-sm p-4 mb-4">
        <h2 class="h5 mb-3">Search and Filter</h2>
        <form action="/staff" method="GET" class="row g-3">
            <div class="col-md-4">
                <label for="search" class="form-label">Search</label>
                <input type="text" id="search" name="search" class="form-control" placeholder="Name or email" value="<%= filters.search %>">
            </div>
            <div class="col-md-3">
                <label for="position" class="form-label">Position</label>
                <input type="text" id="position" name="position" class="form-control" placeholder="Position" value="<%= filters.position %>">
            </div>
            <div class="col-md-3">
                <label for="availabilityStatus" class="form-label">Availability</label>
                <select id="availabilityStatus" name="availabilityStatus" class="form-select">
                    <option value="">All</option>
                    <option value="Available" <%= filters.availabilityStatus === 'Available' ? 'selected' : '' %>>Available</option>
                    <option value="Unavailable" <%= filters.availabilityStatus === 'Unavailable' ? 'selected' : '' %>>Unavailable</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">Search</button>
                <a href="/staff" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </section>
    <section class="bg-white border rounded-3 shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-bottom">
            <h2 class="h5 mb-1">Staff Records</h2>
            <p class="text-muted small mb-0">All matching staff members are shown below.</p>
        </div>
        <% if (staff.length === 0) { %>
            <div class="text-center p-5">
                <h3 class="h5">No staff records found</h3>
                <p class="text-muted mb-3">Try changing the search filters or add a staff member.</p>
                <a href="/staff/create" class="btn btn-primary">Add Staff</a>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Position</th>
                            <th>Availability</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% staff.forEach((staffMember) => { %>
                            <tr>
                                <td class="fw-semibold"><%= staffMember.fullName %></td>
                                <td><%= staffMember.email %></td>
                                <td><%= staffMember.phone || 'Not provided' %></td>
                                <td><%= staffMember.position %></td>
                                <td>
                                    <% if (staffMember.availabilityStatus === 'Available') { %>
                                        <span class="badge text-bg-success">Available</span>
                                    <% } else { %>
                                        <span class="badge text-bg-secondary">Unavailable</span>
                                    <% } %>
                                </td>
                                <td class="text-end">
                                    <a href="/staff/<%= staffMember.staffID %>" class="btn btn-sm btn-outline-primary">View</a>
                                    <a href="/staff/<%= staffMember.staffID %>/edit" class="btn btn-sm btn-warning">Edit</a>
                                    <% if (staffMember.availabilityStatus === 'Unavailable') { %>
                                        <form action="/staff/<%= staffMember.staffID %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this staff member?');">
                                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </section>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>